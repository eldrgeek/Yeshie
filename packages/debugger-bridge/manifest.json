{
  "manifest_version": 3,
  "name": "Yeshie Debugger Bridge",
  "version": "1.0.0",
  "description": "Bridges window.postMessage to chrome.debugger for trusted Input.insertText events",
  "permissions": ["debugger", "tabs"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ]
}
