{
  "_meta": {
    "task": "user-add",
    "description": "Add (onboard) a new person to YeshID. Navigates to the onboard form, fills all fields, and submits.",
    "requiredParams": [
      "first_name",
      "last_name",
      "backup_email",
      "start_date_preset"
    ],
    "optionalParams": [],
    "selfImproving": true,
    "runCount": 5,
    "lastSuccess": "2026-04-14T00:00:00Z",
    "prerequisite": "00-login.payload.json",
    "auth": {
      "type": "sso_automatable",
      "googleAccountEmail": "mw@mike-wolf.com"
    },
    "params": {
      "first_name": {
        "required": true,
        "description": "First name"
      },
      "last_name": {
        "required": true,
        "description": "Last name"
      },
      "company_email": {
        "required": false,
        "description": "Company email \u2014 auto-derived from first and last name",
        "derived": true,
        "derivationTemplate": "{first_name_lower}.{last_name_lower}@embeddedsystemsresearch.org",
        "confirmDerived": true,
        "pattern": "^[a-z]+\\.[a-z]+@embeddedsystemsresearch\\.org$",
        "hint": "Auto-derived as firstname.lastname@embeddedsystemsresearch.org \u2014 confirm or correct before running"
      },
      "backup_email": {
        "required": true,
        "description": "Personal/recovery email (e.g. Gmail)",
        "hint": "Ask if not provided \u2014 this is required by YeshID"
      },
      "start_date_preset": {
        "required": true,
        "description": "When should this person start?",
        "promptLabel": "When should they start?",
        "options": [
          "Immediately",
          "Monday morning",
          "Pick date & time"
        ],
        "hint": "Always ask \u2014 never default silently to Immediately"
      }
    },
    "homeBookend": true,
    "verificationStrategy": {
      "pre": "h0c stores initial_active_people",
      "post": "hZc stores final_active_people",
      "assertion": "final_active_people.numericValue == initial_active_people.numericValue + 1",
      "note": "NEEDS UPDATE: 'Active people in YeshID' label does not exist on current overview page. Use 'Total Applications' for statByLabel smoke test. True people count verification requires /organization/people or /organization/directories page.",
      "mechanism": "statByLabel \u2014 prev-sibling and ancestor-depth walk. 'Total Applications' confirmed working (returns 4). 'Initial directory' label found but numeric neighbor not reachable within 3 ancestor levels.",
      "workingLabel": "Total Applications",
      "workingLabelValue": 4,
      "primaryVerification": "confirmation_message == 'Onboarding workflow created' AND workflow_confirmation contains 'Workflow Run'"
    }
  },
  "runId": "yeshid-user-add-{{timestamp}}",
  "mode": "verification",
  "site": "app.yeshid.com",
  "params": {
    "first_name": "{{first_name}}",
    "last_name": "{{last_name}}",
    "company_email": "{{company_email}}",
    "backup_email": "{{backup_email}}",
    "base_url": "https://app.yeshid.com",
    "start_date_preset": "{{start_date_preset}}"
  },
  "abstractTargets": {
    "first-name-input": {
      "match": {
        "role": "textbox",
        "vuetify_label": [
          "first name"
        ]
      },
      "cachedSelector": "[data-cy=\"first-name-input\"] input",
      "cachedConfidence": 1.0,
      "resolveHint": "data-cy wrapper confirmed stable. Inner input via [data-cy=\"first-name-input\"] input.",
      "resolvedOn": "2026-04-15T00:00:00Z",
      "resolvedVia": "data-cy"
    },
    "last-name-input": {
      "match": {
        "role": "textbox",
        "vuetify_label": [
          "last name"
        ]
      },
      "cachedSelector": "[data-cy=\"last-name-input\"] input",
      "cachedConfidence": 1.0,
      "resolveHint": "data-cy wrapper. data-cy=\"last-name-input\" confirmed present on the last name div.",
      "resolvedOn": "2026-04-15T00:00:00Z",
      "resolvedVia": "data-cy"
    },
    "company-email-input": {
      "match": {
        "role": "textbox",
        "vuetify_label": [
          "company email"
        ]
      },
      "cachedSelector": "[data-cy=\"company-email-input\"] input",
      "cachedConfidence": 1.0,
      "resolveHint": "data-cy wrapper. [data-cy=\"company-email-input\"] input confirmed.",
      "resolvedOn": "2026-04-15T00:00:00Z",
      "resolvedVia": "data-cy"
    },
    "personal-email-input": {
      "match": {
        "role": "textbox",
        "vuetify_label": [
          "personal",
          "recovery"
        ]
      },
      "cachedSelector": "[data-cy=\"recovery-email-input\"] input",
      "cachedConfidence": 1.0,
      "resolveHint": "YeshID uses data-cy=\"recovery-email-input\" (not personal). Inner input via [data-cy=\"recovery-email-input\"] input.",
      "resolvedOn": "2026-04-15T00:00:00Z",
      "resolvedVia": "data-cy"
    },
    "create-onboard-button": {
      "match": {
        "role": "button",
        "name_contains": [
          "create and onboard",
          "onboard person"
        ]
      },
      "cachedSelector": null,
      "cachedConfidence": 0.85,
      "fallbackSelectors": [
        "button.v-btn--variant-flat",
        "button:last-of-type"
      ],
      "resolvedOn": "2026-03-31T00:11:57.745179+00:00",
      "resolvedVia": "aria"
    },
    "start-date-picker": {
      "match": {
        "role": "button",
        "name_contains": [
          "select start date",
          "start date"
        ]
      },
      "cachedSelector": "[data-cy=\"schedule-user-activator\"]",
      "cachedConfidence": 1.0,
      "resolveHint": "data-cy=\"schedule-user-activator\" is the start date button directly. Click opens preset picker.",
      "pickerOptions": [
        "Immediately",
        "ASAP",
        "Monday morning",
        "Pick date & time"
      ],
      "resolvedOn": "2026-04-15T00:00:00Z",
      "resolvedVia": "data-cy"
    },
    "search-input": {
      "match": {
        "role": "textbox",
        "name_contains": [
          "search"
        ]
      },
      "cachedSelector": ".search-input",
      "cachedConfidence": 0.95,
      "resolvedOn": "2026-04-14T00:00:00Z",
      "resolvedVia": "class_match",
      "resolveHint": "Input with class search-input and placeholder Search on the people list page."
    }
  },
  "chain": [
    {
      "stepId": "h0",
      "action": "navigate",
      "url": "https://app.yeshid.com/overview",
      "note": "HOME START: Navigate to overview dashboard before performing action."
    },
    {
      "stepId": "h0b",
      "action": "wait_for",
      "selector": "[data-cy=\"username\"]",
      "timeout": 5000,
      "note": "Wait for page to render \u2014 username data-cy is present on every authenticated page."
    },
    {
      "stepId": "h0c",
      "action": "js",
      "code": "statByLabel('Total Applications')",
      "store_as": "initial_active_people",
      "note": "BOOKEND PLACEHOLDER: 'Active people in YeshID' not on overview. Using Total Applications (does not change on user-add). Real verification is snackbar + /workflows/ redirect."
    },
    {
      "stepId": "s1",
      "action": "assess_state",
      "expect": {
        "state": "authenticated"
      },
      "onMismatch": "branch:not-authenticated"
    },
    {
      "stepId": "s2",
      "action": "navigate",
      "url": "{{base_url}}/organization/people/onboard",
      "guard": {
        "target": "first-name-input",
        "state": {
          "visible": true
        },
        "timeout": 6000
      },
      "expect": {
        "state": "onboard-form"
      }
    },
    {
      "stepId": "s2b",
      "action": "click_preset",
      "target": "start-date-picker",
      "preset": "{{start_date_preset}}",
      "defaultPreset": "Immediately",
      "note": "Required field. Click the start date button then select a preset. Defaults to Immediately."
    },
    {
      "stepId": "s3",
      "action": "type",
      "target": "first-name-input",
      "value": "{{first_name}}",
      "guard": {
        "target": "first-name-input",
        "state": {
          "visible": true,
          "enabled": true
        }
      }
    },
    {
      "stepId": "s4",
      "action": "type",
      "target": "last-name-input",
      "value": "{{last_name}}",
      "guard": {
        "target": "last-name-input",
        "state": {
          "visible": true,
          "enabled": true
        }
      }
    },
    {
      "stepId": "s5",
      "action": "type",
      "target": "company-email-input",
      "value": "{{company_email}}",
      "guard": {
        "target": "company-email-input",
        "state": {
          "visible": true,
          "enabled": true
        }
      }
    },
    {
      "stepId": "s6",
      "action": "type",
      "target": "personal-email-input",
      "value": "{{backup_email}}",
      "guard": {
        "target": "personal-email-input",
        "state": {
          "visible": true,
          "enabled": true
        }
      },
      "note": "Personal / recovery email. Required by YeshID. Pass backup_email param."
    },
    {
      "stepId": "s7",
      "action": "click",
      "target": "create-onboard-button",
      "guard": {
        "target": "create-onboard-button",
        "state": {
          "visible": true,
          "enabled": true
        }
      },
      "responseSignature": [
        {
          "any_of": [
            {
              "type": "url_change",
              "matches": "/workflows/",
              "timeout": 12000,
              "note": "YeshID redirects to /workflows/UUID on successful onboard"
            },
            {
              "type": "url_change",
              "matches": "/organization/people$",
              "timeout": 12000
            },
            {
              "type": "element_visible",
              "selector": ".v-snackbar--active",
              "textMatch": "success|created|added|onboard",
              "timeout": 8000
            }
          ]
        }
      ],
      "failureSignature": [
        {
          "any_of": [
            {
              "type": "element_visible",
              "selector": ".v-snackbar--active",
              "textMatch": "Error|error|failed|required|invalid",
              "timeout": 5000
            },
            {
              "type": "element_visible",
              "selector": ".v-input--error",
              "timeout": 3000,
              "note": "Inline field validation error \u2014 one or more fields failed"
            },
            {
              "type": "element_text",
              "selector": ".v-messages__message, .v-input--error .v-messages",
              "textPattern": "required|invalid|must|fill",
              "timeout": 3000
            }
          ]
        }
      ]
    },
    {
      "stepId": "s7b",
      "action": "read",
      "candidates": [
        ".v-input--error .v-label",
        ".v-input--error label",
        ".v-messages__message"
      ],
      "store_as": "validation_errors",
      "optional": true,
      "note": "Read which fields have inline validation errors after submit. Only populated if s7 triggered failureSignature."
    },
    {
      "stepId": "s8b",
      "action": "assess_state",
      "expect": {
        "state_any": [
          "people-list",
          "onboard-workflow"
        ]
      },
      "note": "Verify redirect \u2014 success lands on /workflows/UUID (workflow kicked off) or /organization/people",
      "onMismatch": "report_failure"
    },
    {
      "stepId": "s8c",
      "action": "read",
      "candidates": [
        "h1",
        ".workflow-title",
        "title",
        ".v-snackbar--active .v-snackbar__content",
        ".v-toolbar__title"
      ],
      "store_as": "workflow_confirmation",
      "optional": true,
      "note": "VERIFY: Read page title or snackbar on workflow/people page to confirm user name was created."
    },
    {
      "stepId": "s8",
      "action": "read",
      "candidates": [
        ".v-snackbar--active .v-snackbar__content",
        ".v-snackbar .v-snackbar__content"
      ],
      "store_as": "confirmation_message",
      "minLength": 1,
      "note": "Capture the success/error message from the snackbar."
    },
    {
      "stepId": "hZ",
      "action": "navigate",
      "url": "https://app.yeshid.com/overview",
      "note": "HOME END: Return to overview dashboard after action completes."
    },
    {
      "stepId": "hZb",
      "action": "wait_for",
      "selector": "[data-cy=\"username\"]",
      "timeout": 5000,
      "note": "Wait for page to render \u2014 username data-cy is present on every authenticated page."
    },
    {
      "stepId": "hZc",
      "action": "js",
      "code": "statByLabel('Total Applications')",
      "store_as": "final_active_people",
      "note": "BOOKEND PLACEHOLDER: Same as h0c. For true user-count bookend, navigate to /organization/directories and parse 'Identities (N)' button text."
    }
  ],
  "branches": {
    "not-authenticated": {
      "description": "Not logged in \u2014 run login flow first.",
      "steps": [
        {
          "stepId": "b1",
          "action": "assert",
          "condition": "false",
          "message": "Not authenticated. The auth flow should handle login automatically."
        }
      ]
    }
  },
  "stateGraph": {
    "nodes": {
      "unauthenticated": {
        "signals": [
          {
            "type": "url_matches",
            "pattern": "/login|/auth|/signin|accounts\\.google\\.com"
          }
        ]
      },
      "authenticated": {
        "signals": [
          {
            "type": "url_matches",
            "pattern": "app\\.yeshid\\.com"
          },
          {
            "type": "url_not_matches",
            "pattern": "/login|/auth|/signin|accounts\\.google\\.com"
          }
        ]
      },
      "people-list": {
        "signals": [
          {
            "type": "url_matches",
            "pattern": "/organization/people$"
          }
        ]
      },
      "onboard-form": {
        "signals": [
          {
            "type": "url_matches",
            "pattern": "/organization/people/onboard"
          }
        ]
      },
      "person-detail": {
        "signals": [
          {
            "type": "url_matches",
            "pattern": "/organization/people/[a-z0-9-]+"
          },
          {
            "type": "url_not_matches",
            "pattern": "/onboard|/offboard"
          }
        ]
      },
      "directories": {
        "signals": [
          {
            "type": "url_matches",
            "pattern": "/organization/directories"
          }
        ]
      },
      "access-grid": {
        "signals": [
          {
            "type": "url_matches",
            "pattern": "/access/grid"
          }
        ]
      },
      "events": {
        "signals": [
          {
            "type": "url_matches",
            "pattern": "/events$"
          }
        ]
      },
      "onboard-workflow": {
        "signals": [
          {
            "type": "url_matches",
            "pattern": "/workflows/[a-z0-9-]+"
          }
        ]
      },
      "overview": {
        "signals": [
          {
            "type": "url_matches",
            "pattern": "/overview$"
          }
        ]
      }
    }
  }
}