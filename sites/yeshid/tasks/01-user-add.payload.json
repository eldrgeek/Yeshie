        "state": "onboard-form"
      }
    },
    {
      "stepId": "s2b",
      "action": "click_preset",
      "target": "start-date-picker",
      "preset": "{{start_date_preset}}",
      "defaultPreset": "Immediately",
      "note": "Required field. Click the start date button then select a preset. Defaults to Immediately."
    },
    {
      "stepId": "s3",
      "action": "type",
      "target": "first-name-input",
      "value": "{{first_name}}",
      "guard": {
        "target": "first-name-input",
        "state": {
          "visible": true,
          "enabled": true
        }
      }
    },
    {
      "stepId": "s4",
      "action": "type",
      "target": "last-name-input",
      "value": "{{last_name}}",
      "guard": {
        "target": "last-name-input",
        "state": {
          "visible": true,
          "enabled": true
        }
      }
    },
    {
      "stepId": "s5",
      "action": "type",
      "target": "company-email-input",
      "value": "{{company_email}}",
      "guard": {
        "target": "company-email-input",
        "state": {
          "visible": true,
          "enabled": true
        }
      }
    },
    {
      "stepId": "s6",
      "action": "type",
      "target": "personal-email-input",
      "value": "{{backup_email}}",
      "guard": {
        "target": "personal-email-input",
        "state": {
          "visible": true,
          "enabled": true
        }
      },
      "note": "Personal / recovery email. Required by YeshID. Pass backup_email param."
    },
    {
      "stepId": "s7",
      "action": "click",
      "target": "create-onboard-button",
      "guard": {
        "target": "create-onboard-button",
        "state": {
          "visible": true,
          "enabled": true
        }
      },
      "responseSignature": [
        {
          "any_of": [
            {
              "type": "url_change",
              "matches": "/organization/people$",
              "timeout": 8000
            },
            {
              "type": "element_visible",
              "selector": ".v-snackbar--active",
              "textMatch": "success|created|added|onboard",
              "timeout": 5000
            }
          ]
        }
      ],
      "failureSignature": [
        {
          "any_of": [
            {
              "type": "element_visible",
              "selector": ".v-snackbar--active",
              "textMatch": "Error|error|failed|required|invalid",
              "timeout": 5000
            },
            {
              "type": "element_text",
              "selector": ".v-messages__message, .v-input--error .v-messages",
              "textPattern": "required|invalid|must",
              "timeout": 5000
            }
          ]
        }
      ]
    },
    {
      "stepId": "s8",
      "action": "read",
      "candidates": [
        ".v-snackbar--active .v-snackbar__content",
        ".v-snackbar .v-snackbar__content"
      ],
      "store_as": "confirmation_message",
      "minLength": 1,
      "note": "Capture the success/error message from the snackbar."
    }
  ],
  "branches": {
    "not-authenticated": {
      "description": "Not logged in \u2014 run login flow first.",
      "steps": [
        {
          "stepId": "b1",
          "action": "js",
