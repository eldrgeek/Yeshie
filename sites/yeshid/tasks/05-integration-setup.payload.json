{
  "_meta": {
    "task": "integration-setup",
    "description": "Set up a SCIM integration for an application in YeshID. Creates the app first if needed, then configures SCIM with Bearer auth.",
    "params": {
      "app_name": {"required": true, "description": "Name of the application to integrate"},
      "technical_owner": {"required": true, "description": "Email of the technical owner"},
      "technical_owner_name": {"required": false, "default": "Mike Wolf", "description": "Display name of technical owner"},
      "api_base_url": {"required": true, "description": "SCIM base URL (e.g. https://api.example.com/scim/v2)"},
      "bearer_token": {"required": true, "description": "Bearer token for SCIM auth"},
      "auth_type": {"required": false, "default": "Bearer", "description": "Auth type: Bearer, OAuth2, Basic, Custom API key, None"}
    },
    "selfImproving": true,
    "runCount": 0,
    "lastSuccess": null,
    "prerequisite": "00-login.payload.json",
    "note": "Before running: (1) look up the service's SCIM endpoint and token, (2) populate params accordingly.",
    "auth": {
      "type": "sso_automatable",
      "googleAccountEmail": "mw@mike-wolf.com"
    }
  },
  "params": {
    "base_url": "https://app.yeshid.com",
    "app_name": "",
    "technical_owner": "",
    "technical_owner_name": "Mike Wolf",
    "api_base_url": "",
    "bearer_token": "",
    "auth_type": "Bearer"
  },
  "chain": [
    {
      "stepId": "s1",
      "action": "assess_state",
      "expect": {"state": "authenticated"},
      "onMismatch": "exit_with_error:not-authenticated"
    },
    {
      "stepId": "s2",
      "action": "navigate",
      "url": "{{base_url}}/access/applications",
      "note": "Go to applications list"
    },
    {
      "stepId": "s3",
      "action": "delay",
      "ms": 2000
    },
    {
      "stepId": "s4",
      "action": "click_text",
      "text": "Add application",
      "note": "Open Add Application dialog"
    },
    {
      "stepId": "s5",
      "action": "delay",
      "ms": 1500
    },
    {
      "stepId": "s6",
      "action": "type",
      "selector": "input[placeholder='Type application name']",
      "value": "{{app_name}}"
    },
    {
      "stepId": "s7",
      "action": "delay",
      "ms": 500
    },
    {
      "stepId": "s8",
      "action": "select_entity",
      "selector": "input[placeholder='Select technical owners']",
      "search": "{{technical_owner}}",
      "select_text": "{{technical_owner_name}}",
      "delay_ms": 2500,
      "note": "Select technical owner from unified-selection-shell dropdown"
    },
    {
      "stepId": "s9",
      "action": "delay",
      "ms": 1000
    },
    {
      "stepId": "s10",
      "action": "click_text",
      "text": "Add",
      "exact": true,
      "note": "Submit the Add Application dialog"
    },
    {
      "stepId": "s11",
      "action": "delay",
      "ms": 2000,
      "note": "Wait for app creation and redirect to app detail"
    },
    {
      "stepId": "s12",
      "action": "navigate",
      "url": "{{base_url}}/access/applications",
      "note": "Return to applications list to find the new app"
    },
    {
      "stepId": "s13",
      "action": "delay",
      "ms": 2000
    },
    {
      "stepId": "s14",
      "action": "find_row",
      "identifier": "{{app_name}}",
      "click": true,
      "note": "Click on the newly created app row"
    },
    {
      "stepId": "s15",
      "action": "delay",
      "ms": 2000
    },
    {
      "stepId": "s16",
      "action": "click_text",
      "text": "Connect",
      "note": "Open integration setup panel"
    },
    {
      "stepId": "s17",
      "action": "delay",
      "ms": 1500
    },
    {
      "stepId": "s18",
      "action": "click_text",
      "text": "SCIM",
      "note": "Select SCIM integration type"
    },
    {
      "stepId": "s19",
      "action": "delay",
      "ms": 500
    },
    {
      "stepId": "s20",
      "action": "click_text",
      "text": "{{auth_type}}",
      "note": "Select auth type (Bearer by default)"
    },
    {
      "stepId": "s21",
      "action": "delay",
      "ms": 500
    },
    {
      "stepId": "s22",
      "action": "type",
      "selector": "input[placeholder='https://']",
      "value": "{{api_base_url}}",
      "note": "Fill SCIM base URL"
    },
    {
      "stepId": "s23",
      "action": "type",
      "selector": "input[type='password']",
      "value": "{{bearer_token}}",
      "note": "Fill bearer token"
    },
    {
      "stepId": "s24",
      "action": "delay",
      "ms": 500
    },
    {
      "stepId": "s25",
      "action": "click_text",
      "text": "Save",
      "exact": true,
      "note": "Save integration configuration"
    }
  ],
  "preRunChecklist": {
    "description": "Steps to complete BEFORE running this payload.",
    "steps": [
      "1. Look up the service's SCIM provisioning endpoint URL",
      "2. Generate a SCIM/API bearer token from the service's admin console",
      "3. Populate params: app_name, technical_owner, api_base_url, bearer_token"
    ]
  }
}
