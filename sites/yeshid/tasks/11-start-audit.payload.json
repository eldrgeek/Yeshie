{
  "_meta": {
    "task": "start-audit",
    "description": "Start a new access audit from the audit reports page.",
    "params": {
      "audit_title": {
        "required": true,
        "description": "Title for the access audit",
        "hint": "e.g. \"Q2 2026 Access Review\""
      }
    },
    "selfImproving": true,
    "runCount": 0,
    "lastSuccess": null,
    "auth": {
      "type": "sso_automatable",
      "googleAccountEmail": "mw@mike-wolf.com"
    },
    "requiredParams": [
      "audit_title"
    ],
    "optionalParams": []
  },
  "params": {
    "base_url": "https://app.yeshid.com",
    "audit_title": ""
  },
  "chain": [
    {
      "stepId": "s1",
      "action": "assess_state",
      "expect": {
        "state": "authenticated"
      },
      "onMismatch": "exit_with_error:not-authenticated"
    },
    {
      "stepId": "s2",
      "action": "navigate",
      "url": "{{base_url}}/access/audits"
    },
    {
      "stepId": "s3",
      "action": "delay",
      "ms": 1500
    },
    {
      "stepId": "s4",
      "action": "click_text",
      "text": "Start new audit",
      "note": "Click Start new audit button"
    },
    {
      "stepId": "s5",
      "action": "delay",
      "ms": 1500,
      "note": "Wait for audit form to open"
    },
    {
      "stepId": "s6",
      "action": "type",
      "selector": "input",
      "value": "{{audit_title}}",
      "condition": "{{audit_title}}",
      "note": "Type audit title if provided"
    },
    {
      "stepId": "s7",
      "action": "read",
      "store_as": "audit_form",
      "note": "Capture audit form state for review before submission"
    }
  ],
  "stateGraph": {
    "nodes": {
      "unauthenticated": {
        "signals": [
          {
            "type": "url_matches",
            "pattern": "/login|/auth|/signin|accounts\\.google\\.com"
          }
        ]
      },
      "authenticated": {
        "signals": [
          {
            "type": "url_matches",
            "pattern": "app\\.yeshid\\.com"
          },
          {
            "type": "url_not_matches",
            "pattern": "/login|/auth|/signin|accounts\\.google\\.com"
          }
        ]
      },
      "people-list": {
        "signals": [
          {
            "type": "url_matches",
            "pattern": "/organization/people$"
          }
        ]
      },
      "onboard-form": {
        "signals": [
          {
            "type": "url_matches",
            "pattern": "/organization/people/onboard"
          }
        ]
      },
      "person-detail": {
        "signals": [
          {
            "type": "url_matches",
            "pattern": "/organization/people/[a-z0-9-]+"
          },
          {
            "type": "url_not_matches",
            "pattern": "/onboard|/offboard"
          }
        ]
      },
      "directories": {
        "signals": [
          {
            "type": "url_matches",
            "pattern": "/organization/directories"
          }
        ]
      },
      "access-grid": {
        "signals": [
          {
            "type": "url_matches",
            "pattern": "/access/grid"
          }
        ]
      },
      "events": {
        "signals": [
          {
            "type": "url_matches",
            "pattern": "/events$"
          }
        ]
      }
    }
  }
}
