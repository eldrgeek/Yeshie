{
  "_meta": {
    "task": "q01-count-by-status",
    "queryType": "read_only",
    "description": "Count YeshID users by status. Navigates to /organization/people with URL-based status filters and reads totals from the pagination footer. Returns { active, deactivated, staged_offboarding, total }.",
    "selfImproving": false,
    "runCount": 0,
    "lastSuccess": null,
    "requiredParams": [],
    "optionalParams": [],
    "auth": {
      "type": "sso_automatable",
      "googleAccountEmail": "mw@mike-wolf.com"
    },
    "discoveredFilters": {
      "note": "URL filter pattern confirmed via exploration-results.json: dashboard 'View all' uses ?filters=status=ACTIVE. Tested live: ACTIVE=28, DEACTIVATED=3, STAGED_OFFBOARDING=0, total=31.",
      "knownStatuses": ["ACTIVE", "DEACTIVATED", "STAGED_OFFBOARDING", "STAGED"]
    }
  },
  "runId": "yeshid-q01-count-by-status-{{timestamp}}",
  "mode": "query",
  "site": "app.yeshid.com",
  "params": {
    "base_url": "https://app.yeshid.com"
  },
  "abstractTargets": {
    "pagination-footer": {
      "match": { "css": ".v-data-table-footer" },
      "cachedSelector": ".v-data-table-footer",
      "cachedConfidence": 0.97,
      "resolveHint": "Footer below the data table. Contains text matching 'Items per page:10 1-10 of TOTAL'. Extract TOTAL (number after 'of ')."
    }
  },
  "chain": [
    {
      "stepId": "s1",
      "action": "assess_state",
      "expect": { "state": "authenticated" },
      "onMismatch": "exit_with_error:not-authenticated"
    },
    {
      "stepId": "s2",
      "action": "navigate",
      "url": "{{base_url}}/organization/people?filters=status=ACTIVE",
      "note": "URL filter confirmed from site exploration. dashboard 'View all active' uses this exact href."
    },
    {
      "stepId": "s3",
      "action": "wait_for",
      "selector": ".v-data-table-footer",
      "timeout": 6000,
      "note": "Wait for Vue table and pagination footer to render."
    },
    {
      "stepId": "s4",
      "action": "perceive",
      "selector": ".v-data-table-footer",
      "store_as": "active_footer",
      "note": "Footer shows e.g. 'Items per page:10 1-10 of 28'. Total is the number after 'of'."
    },
    {
      "stepId": "s5",
      "action": "navigate",
      "url": "{{base_url}}/organization/people?filters=status=DEACTIVATED"
    },
    {
      "stepId": "s6",
      "action": "wait_for",
      "selector": ".v-data-table-footer",
      "timeout": 6000
    },
    {
      "stepId": "s7",
      "action": "perceive",
      "selector": ".v-data-table-footer",
      "store_as": "deactivated_footer"
    },
    {
      "stepId": "s8",
      "action": "navigate",
      "url": "{{base_url}}/organization/people?filters=status=STAGED_OFFBOARDING",
      "note": "Staged-for-offboarding users. Currently 0 in this org but pattern is valid."
    },
    {
      "stepId": "s9",
      "action": "wait_for",
      "selector": ".v-data-table-footer",
      "timeout": 6000
    },
    {
      "stepId": "s10",
      "action": "perceive",
      "selector": ".v-data-table-footer",
      "store_as": "staged_offboarding_footer"
    },
    {
      "stepId": "s11",
      "action": "navigate",
      "url": "{{base_url}}/organization/people",
      "note": "No filter — grand total of all users regardless of status."
    },
    {
      "stepId": "s12",
      "action": "wait_for",
      "selector": ".v-data-table-footer",
      "timeout": 6000
    },
    {
      "stepId": "s13",
      "action": "perceive",
      "selector": ".v-data-table-footer",
      "store_as": "total_footer"
    },
    {
      "stepId": "s14",
      "action": "respond",
      "extract_from": {
        "active":             { "source": "active_footer",             "pattern": "of (\\d+)", "capture": 1 },
        "deactivated":        { "source": "deactivated_footer",        "pattern": "of (\\d+)", "capture": 1 },
        "staged_offboarding": { "source": "staged_offboarding_footer", "pattern": "of (\\d+)", "capture": 1 },
        "total":              { "source": "total_footer",              "pattern": "of (\\d+)", "capture": 1 }
      },
      "note": "Parse total from each footer's 'N-N of TOTAL' text. Return structured counts."
    }
  ],
  "stateGraph": {
    "nodes": {
      "unauthenticated": {
        "signals": [{ "type": "url_matches", "pattern": "/login|/auth|/signin|accounts\\.google\\.com" }]
      },
      "authenticated": {
        "signals": [
          { "type": "url_matches", "pattern": "app\\.yeshid\\.com" },
          { "type": "url_not_matches", "pattern": "/login|/auth|/signin|accounts\\.google\\.com" }
        ]
      },
      "people-list": {
        "signals": [{ "type": "url_matches", "pattern": "/organization/people" }]
      }
    }
  }
}
