{
  "_meta": {
    "task": "sync-directory",
    "description": "Navigate to directories page and trigger a directory sync.",
    "params": [
      "base_url"
    ],
    "selfImproving": true,
    "runCount": 0,
    "lastSuccess": null,
    "auth": {
      "type": "sso_automatable",
      "googleAccountEmail": "mw@mike-wolf.com"
    }
  },
  "params": {
    "base_url": "https://app.yeshid.com"
  },
  "chain": [
    {
      "stepId": "s1",
      "action": "assess_state",
      "expect": {
        "state": "authenticated"
      },
      "onMismatch": "exit_with_error:not-authenticated"
    },
    {
      "stepId": "s2",
      "action": "click",
      "target": "nav-directories",
      "note": "Click Directories in sidebar nav"
    },
    {
      "stepId": "s3",
      "action": "delay",
      "ms": 2000,
      "note": "Wait for directory page to load"
    },
    {
      "stepId": "s4",
      "action": "assess_state",
      "expect": {
        "state": "directories"
      }
    },
    {
      "stepId": "s5",
      "action": "click_text",
      "text": "Sync directory",
      "note": "Click the sync directory button"
    },
    {
      "stepId": "s6",
      "action": "delay",
      "ms": 3000,
      "note": "Wait for sync to initiate"
    },
    {
      "stepId": "s7",
      "action": "read",
      "store_as": "sync_result",
      "note": "Capture page state after sync trigger"
    }
  ],
  "stateGraph": {
    "nodes": {
      "unauthenticated": {
        "signals": [
          {
            "type": "url_matches",
            "pattern": "/login|/auth|/signin|accounts\\.google\\.com"
          }
        ]
      },
      "authenticated": {
        "signals": [
          {
            "type": "url_matches",
            "pattern": "app\\.yeshid\\.com"
          },
          {
            "type": "url_not_matches",
            "pattern": "/login|/auth|/signin|accounts\\.google\\.com"
          }
        ]
      },
      "people-list": {
        "signals": [
          {
            "type": "url_matches",
            "pattern": "/organization/people$"
          }
        ]
      },
      "onboard-form": {
        "signals": [
          {
            "type": "url_matches",
            "pattern": "/organization/people/onboard"
          }
        ]
      },
      "person-detail": {
        "signals": [
          {
            "type": "url_matches",
            "pattern": "/organization/people/[a-z0-9-]+"
          },
          {
            "type": "url_not_matches",
            "pattern": "/onboard|/offboard"
          }
        ]
      },
      "directories": {
        "signals": [
          {
            "type": "url_matches",
            "pattern": "/organization/directories"
          }
        ]
      },
      "access-grid": {
        "signals": [
          {
            "type": "url_matches",
            "pattern": "/access/grid"
          }
        ]
      },
      "events": {
        "signals": [
          {
            "type": "url_matches",
            "pattern": "/events$"
          }
        ]
      }
    }
  }
}
