{
  "_meta": {
    "task": "view-events",
    "description": "Navigate to events page and optionally search for specific events.",
    "params": {
      "search_term": {
        "required": false,
        "default": "",
        "description": "Event search term (leave blank to show all recent events)"
      }
    },
    "selfImproving": true,
    "runCount": 0,
    "lastSuccess": null,
    "auth": {
      "type": "sso_automatable",
      "googleAccountEmail": "mw@mike-wolf.com"
    },
    "requiredParams": [],
    "optionalParams": [
      "search_term"
    ]
  },
  "params": {
    "base_url": "https://app.yeshid.com",
    "search_term": ""
  },
  "chain": [
    {
      "stepId": "s1",
      "action": "assess_state",
      "expect": {
        "state": "authenticated"
      },
      "onMismatch": "exit_with_error:not-authenticated"
    },
    {
      "stepId": "s2",
      "action": "navigate",
      "url": "{{base_url}}/events"
    },
    {
      "stepId": "s3",
      "action": "delay",
      "ms": 1500
    },
    {
      "stepId": "s4",
      "action": "type",
      "selector": "input[placeholder='Search']",
      "value": "{{search_term}}",
      "condition": "{{search_term}}",
      "note": "Search events if search_term provided"
    },
    {
      "stepId": "s5",
      "action": "delay",
      "ms": 1000,
      "condition": "{{search_term}}"
    },
    {
      "stepId": "s6",
      "action": "read",
      "selector": ".v-data-table",
      "store_as": "events_data",
      "note": "Capture events table"
    }
  ],
  "stateGraph": {
    "nodes": {
      "unauthenticated": {
        "signals": [
          {
            "type": "url_matches",
            "pattern": "/login|/auth|/signin|accounts\\.google\\.com"
          }
        ]
      },
      "authenticated": {
        "signals": [
          {
            "type": "url_matches",
            "pattern": "app\\.yeshid\\.com"
          },
          {
            "type": "url_not_matches",
            "pattern": "/login|/auth|/signin|accounts\\.google\\.com"
          }
        ]
      },
      "people-list": {
        "signals": [
          {
            "type": "url_matches",
            "pattern": "/organization/people$"
          }
        ]
      },
      "onboard-form": {
        "signals": [
          {
            "type": "url_matches",
            "pattern": "/organization/people/onboard"
          }
        ]
      },
      "person-detail": {
        "signals": [
          {
            "type": "url_matches",
            "pattern": "/organization/people/[a-z0-9-]+"
          },
          {
            "type": "url_not_matches",
            "pattern": "/onboard|/offboard"
          }
        ]
      },
      "directories": {
        "signals": [
          {
            "type": "url_matches",
            "pattern": "/organization/directories"
          }
        ]
      },
      "access-grid": {
        "signals": [
          {
            "type": "url_matches",
            "pattern": "/access/grid"
          }
        ]
      },
      "events": {
        "signals": [
          {
            "type": "url_matches",
            "pattern": "/events$"
          }
        ]
      }
    }
  }
}
