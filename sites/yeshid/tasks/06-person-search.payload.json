{
  "_meta": {
    "task": "person-search",
    "description": "Search for a person by name or email. Navigates to the people list, waits for the search input to mount, types the search term, and reads all rows for client-side filtering.",
    "params": {
      "search_term": {
        "required": true,
        "description": "Name or email to search for"
      }
    },
    "selfImproving": true,
    "runCount": 0,
    "lastSuccess": null,
    "auth": {
      "type": "sso_automatable",
      "googleAccountEmail": "mw@mike-wolf.com"
    },
    "requiredParams": [
      "search_term"
    ],
    "optionalParams": []
  },
  "params": {
    "base_url": "https://app.yeshid.com",
    "search_term": ""
  },
  "chain": [
    {
      "stepId": "s1",
      "action": "assess_state",
      "expect": {
        "state": "authenticated"
      },
      "onMismatch": "exit_with_error:not-authenticated"
    },
    {
      "stepId": "s2",
      "action": "navigate",
      "url": "{{base_url}}/organization/people"
    },
    {
      "stepId": "s2b",
      "action": "delay",
      "ms": 2000,
      "note": "Allow Vue app to hydrate after SPA navigation before polling for DOM elements"
    },
    {
      "stepId": "s3",
      "action": "wait_for",
      "selector": "input[placeholder='Search']",
      "timeout": 12000,
      "note": "Wait for Vuetify search input to mount — SPA navigation completes before Vue components render"
    },
    {
      "stepId": "s4",
      "action": "assess_state",
      "expect": {
        "state": "people-list"
      }
    },
    {
      "stepId": "s5",
      "action": "type",
      "selector": "input[placeholder='Search']",
      "value": "{{search_term}}",
      "note": "Type search term — uses CDP Input.insertText which triggers Vue v-model"
    },
    {
      "stepId": "s6",
      "action": "delay",
      "ms": 1500,
      "note": "Wait for Vue reactive filter to settle"
    },
    {
      "stepId": "s7",
      "action": "read",
      "selector": ".v-data-table tbody",
      "store_as": "search_results",
      "note": "Read ALL rows from people table. The search input may not trigger Vue reactive filtering — always return the full table and filter by search_term in the final response. Match search_term against name and email text in each row."
    }
  ],
  "stateGraph": {
    "nodes": {
      "unauthenticated": {
        "signals": [
          {
            "type": "url_matches",
            "pattern": "/login|/auth|/signin|accounts\\.google\\.com"
          }
        ]
      },
      "authenticated": {
        "signals": [
          {
            "type": "url_matches",
            "pattern": "app\\.yeshid\\.com"
          },
          {
            "type": "url_not_matches",
            "pattern": "/login|/auth|/signin|accounts\\.google\\.com"
          }
        ]
      },
      "people-list": {
        "signals": [
          {
            "type": "url_matches",
            "pattern": "/organization/people$"
          }
        ]
      },
      "onboard-form": {
        "signals": [
          {
            "type": "url_matches",
            "pattern": "/organization/people/onboard"
          }
        ]
      },
      "person-detail": {
        "signals": [
          {
            "type": "url_matches",
            "pattern": "/organization/people/[a-z0-9-]+"
          },
          {
            "type": "url_not_matches",
            "pattern": "/onboard|/offboard"
          }
        ]
      },
      "directories": {
        "signals": [
          {
            "type": "url_matches",
            "pattern": "/organization/directories"
          }
        ]
      },
      "access-grid": {
        "signals": [
          {
            "type": "url_matches",
            "pattern": "/access/grid"
          }
        ]
      },
      "events": {
        "signals": [
          {
            "type": "url_matches",
            "pattern": "/events$"
          }
        ]
      }
    }
  }
}
