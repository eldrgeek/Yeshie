{
  "_meta": {
    "task": "login",
    "description": "Ensure the user is authenticated on app.yeshid.com via Google SSO. If already logged in, exits immediately.",
    "params": {
      "google_account_email": {
        "required": false,
        "default": "mw@mike-wolf.com",
        "description": "Google account email for SSO"
      },
      "base_url": {
        "required": false,
        "default": "https://app.yeshid.com",
        "description": "YeshID base URL"
      }
    },
    "selfImproving": true,
    "runCount": 0,
    "lastSuccess": null,
    "auth": {
      "type": "sso_automatable",
      "googleAccountEmail": "mw@mike-wolf.com"
    }
  },
  "runId": "yeshid-login-{{timestamp}}",
  "mode": "verification",
  "site": "app.yeshid.com",
  "chain": [
    {
      "stepId": "s1",
      "action": "navigate",
      "url": "{{base_url}}",
      "note": "Navigate to base URL. If already authenticated, will redirect to /overview."
    },
    {
      "stepId": "s2",
      "action": "assess_state",
      "expect": {
        "state": "authenticated"
      },
      "onMatch": "exit_success",
      "note": "If already authenticated, exit immediately."
    },
    {
      "stepId": "s3",
      "action": "click_text",
      "text": "Sign in with Google",
      "note": "Click the Google SSO button on the YeshID login page."
    },
    {
      "stepId": "s4",
      "action": "delay",
      "ms": 3000,
      "note": "Wait for redirect to accounts.google.com."
    },
    {
      "stepId": "s5",
      "action": "click",
      "selector": "[data-email=\"{{google_account_email}}\"]",
      "note": "Click the matching Google account on the account chooser page."
    },
    {
      "stepId": "s6",
      "action": "wait_for",
      "url_pattern": "app\\.yeshid\\.com(?!/login)",
      "timeout": 30000,
      "note": "Wait for redirect back to app.yeshid.com (not /login)."
    }
  ],
  "stateGraph": {
    "nodes": {
      "unauthenticated": {
        "signals": [
          {
            "type": "url_matches",
            "pattern": "/login|/auth|/signin|accounts\\.google\\.com"
          }
        ]
      },
      "authenticated": {
        "signals": [
          {
            "type": "url_matches",
            "pattern": "app\\.yeshid\\.com"
          },
          {
            "type": "url_not_matches",
            "pattern": "/login|/auth|/signin|accounts\\.google\\.com"
          }
        ]
      }
    }
  }
}
