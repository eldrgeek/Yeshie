{
  "_meta": {
    "task": "add-application",
    "description": "Add a new application to YeshID.",
    "params": {
      "app_name": {
        "required": true,
        "description": "Name of the application to add"
      },
      "technical_owner": {
        "required": true,
        "description": "Email of the technical owner",
        "hint": "Usually an admin \u2014 suggest current user if not specified"
      },
      "technical_owner_name": {
        "required": false,
        "default": "Mike Wolf",
        "description": "Display name of technical owner (for dropdown selection)",
        "hint": "Used to click the right person from search results"
      }
    },
    "selfImproving": true,
    "runCount": 0,
    "lastSuccess": null,
    "auth": {
      "type": "sso_automatable",
      "googleAccountEmail": "mw@mike-wolf.com"
    },
    "requiredParams": [
      "app_name",
      "technical_owner"
    ],
    "optionalParams": []
  },
  "params": {
    "base_url": "https://app.yeshid.com",
    "app_name": "",
    "technical_owner": "",
    "technical_owner_name": "Mike Wolf"
  },
  "chain": [
    {
      "stepId": "s1",
      "action": "assess_state",
      "expect": {
        "state": "authenticated"
      },
      "onMismatch": "exit_with_error:not-authenticated"
    },
    {
      "stepId": "s2",
      "action": "navigate",
      "url": "{{base_url}}/access/applications"
    },
    {
      "stepId": "s3",
      "action": "delay",
      "ms": 2000
    },
    {
      "stepId": "s4",
      "action": "click_text",
      "text": "Add application",
      "note": "Open Add Application dialog"
    },
    {
      "stepId": "s5",
      "action": "delay",
      "ms": 1500,
      "note": "Wait for dialog to render"
    },
    {
      "stepId": "s6",
      "action": "type",
      "selector": "input[placeholder='Type application name']",
      "value": "{{app_name}}",
      "note": "Type application name"
    },
    {
      "stepId": "s7",
      "action": "delay",
      "ms": 500
    },
    {
      "stepId": "s8",
      "action": "select_entity",
      "selector": "input[placeholder='Select technical owners']",
      "search": "{{technical_owner}}",
      "select_text": "{{technical_owner_name}}",
      "delay_ms": 2500,
      "note": "Search and select technical owner"
    },
    {
      "stepId": "s9",
      "action": "delay",
      "ms": 1000
    },
    {
      "stepId": "s10",
      "action": "click_text",
      "text": "Add",
      "exact": true,
      "note": "Click Add button in dialog footer"
    }
  ],
  "stateGraph": {
    "nodes": {
      "unauthenticated": {
        "signals": [
          {
            "type": "url_matches",
            "pattern": "/login|/auth|/signin|accounts\\.google\\.com"
          }
        ]
      },
      "authenticated": {
        "signals": [
          {
            "type": "url_matches",
            "pattern": "app\\.yeshid\\.com"
          },
          {
            "type": "url_not_matches",
            "pattern": "/login|/auth|/signin|accounts\\.google\\.com"
          }
        ]
      },
      "people-list": {
        "signals": [
          {
            "type": "url_matches",
            "pattern": "/organization/people$"
          }
        ]
      },
      "onboard-form": {
        "signals": [
          {
            "type": "url_matches",
            "pattern": "/organization/people/onboard"
          }
        ]
      },
      "person-detail": {
        "signals": [
          {
            "type": "url_matches",
            "pattern": "/organization/people/[a-z0-9-]+"
          },
          {
            "type": "url_not_matches",
            "pattern": "/onboard|/offboard"
          }
        ]
      },
      "directories": {
        "signals": [
          {
            "type": "url_matches",
            "pattern": "/organization/directories"
          }
        ]
      },
      "access-grid": {
        "signals": [
          {
            "type": "url_matches",
            "pattern": "/access/grid"
          }
        ]
      },
      "events": {
        "signals": [
          {
            "type": "url_matches",
            "pattern": "/events$"
          }
        ]
      }
    }
  }
}