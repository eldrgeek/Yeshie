{
  "_meta": {
    "task": "add-application",
    "description": "Add a new application to YeshID.",
    "params": {
      "app_name": {
        "required": true,
        "description": "Name of the application to add"
      },
      "technical_owner": {
        "required": true,
        "description": "Email of the technical owner",
        "hint": "Usually an admin \u2014 suggest current user if not specified"
      }
    },
    "selfImproving": true,
    "runCount": 0,
    "lastSuccess": null,
    "auth": {
      "type": "sso_automatable",
      "googleAccountEmail": "mw@mike-wolf.com"
    },
    "requiredParams": [
      "app_name",
      "technical_owner"
    ],
    "optionalParams": []
  },
  "params": {
    "base_url": "https://app.yeshid.com",
    "app_name": "",
    "technical_owner": ""
  },
  "chain": [
    {
      "stepId": "s1",
      "action": "assess_state",
      "expect": {
        "state": "authenticated"
      },
      "onMismatch": "exit_with_error:not-authenticated"
    },
    {
      "stepId": "s2",
      "action": "navigate",
      "url": "{{base_url}}/access/applications"
    },
    {
      "stepId": "s3",
      "action": "delay",
      "ms": 1500
    },
    {
      "stepId": "s4",
      "action": "click",
      "target": "add-application-button",
      "note": "Click Add application button"
    },
    {
      "stepId": "s5",
      "action": "delay",
      "ms": 1000,
      "note": "Wait for dialog to open"
    },
    {
      "stepId": "s6",
      "action": "type",
      "target": "application-name-input",
      "value": "{{app_name}}",
      "note": "Type application name"
    },
    {
      "stepId": "s7",
      "action": "type",
      "target": "technical-owners-input",
      "value": "{{technical_owner}}",
      "note": "Type technical owner"
    },
    {
      "stepId": "s8",
      "action": "delay",
      "ms": 500
    },
    {
      "stepId": "s9",
      "action": "click",
      "target": "dialog-add-button",
      "responseSignature": {
        "type": "snackbar_text",
        "selector": ".v-snackbar--active .v-snackbar__content"
      },
      "note": "Click Add in dialog and verify success"
    }
  ],
  "stateGraph": {
    "nodes": {
      "unauthenticated": {
        "signals": [
          {
            "type": "url_matches",
            "pattern": "/login|/auth|/signin|accounts\\.google\\.com"
          }
        ]
      },
      "authenticated": {
        "signals": [
          {
            "type": "url_matches",
            "pattern": "app\\.yeshid\\.com"
          },
          {
            "type": "url_not_matches",
            "pattern": "/login|/auth|/signin|accounts\\.google\\.com"
          }
        ]
      },
      "people-list": {
        "signals": [
          {
            "type": "url_matches",
            "pattern": "/organization/people$"
          }
        ]
      },
      "onboard-form": {
        "signals": [
          {
            "type": "url_matches",
            "pattern": "/organization/people/onboard"
          }
        ]
      },
      "person-detail": {
        "signals": [
          {
            "type": "url_matches",
            "pattern": "/organization/people/[a-z0-9-]+"
          },
          {
            "type": "url_not_matches",
            "pattern": "/onboard|/offboard"
          }
        ]
      },
      "directories": {
        "signals": [
          {
            "type": "url_matches",
            "pattern": "/organization/directories"
          }
        ]
      },
      "access-grid": {
        "signals": [
          {
            "type": "url_matches",
            "pattern": "/access/grid"
          }
        ]
      },
      "events": {
        "signals": [
          {
            "type": "url_matches",
            "pattern": "/events$"
          }
        ]
      }
    }
  }
}
