{
  "_meta": {
    "task": "user-modify",
    "description": "Modify an existing user's profile in YeshID. Searches for the user, opens their detail page, updates specified fields, and saves.",
    "params": ["user_identifier", "new_first_name", "new_last_name", "new_personal_email"],
    "paramNotes": {
      "user_identifier": "Name or email to find the user",
      "new_first_name": "New first name (optional, leave empty to skip)",
      "new_last_name": "New last name (optional, leave empty to skip)",
      "new_personal_email": "New personal email (optional, leave empty to skip)"
    },
    "selfImproving": true,
    "runCount": 0,
    "lastSuccess": null,
    "prerequisite": "00-login.payload.json"
  },

  "runId": "yeshid-user-modify-{{timestamp}}",
  "mode": "verification",
  "site": "app.yeshid.com",

  "params": {
    "user_identifier": "{{user_identifier}}",
    "new_first_name": "{{new_first_name}}",
    "new_last_name": "{{new_last_name}}",
    "new_personal_email": "{{new_personal_email}}",
    "base_url": "https://app.yeshid.com"
  },

  "stateGraph": {
    "currentNode": "authenticated",
    "nodes": {
      "authenticated": {
        "signals": [{ "type": "element_visible", "selector": ".v-navigation-drawer a[href='/overview']" }]
      },
      "people-list": {
        "signals": [{ "type": "url_matches", "pattern": "/organization/people$" }]
      },
      "person-detail": {
        "signals": [{ "type": "url_matches", "pattern": "/organization/people/[a-z0-9-]+" }]
      }
    }
  },

  "abstractTargets": {
    "search-input": {
      "match": { "role": "textbox", "name_contains": ["search"] },
      "cachedSelector": "input[placeholder='Search']",
      "cachedConfidence": 0.90
    },
    "save-button": {
      "match": { "role": "button", "name_contains": ["confirm", "save", "update"] },
      "cachedSelector": null,
      "cachedConfidence": 0.0,
      "fallbackSelectors": ["button.bg-primary", "button.v-btn--variant-flat", "button[type='submit']"]
    },
    "edit-first-name": {
      "match": { "role": "textbox", "vuetify_label": ["first name"] },
      "cachedSelector": null,
      "cachedConfidence": 0.0
    },
    "edit-last-name": {
      "match": { "role": "textbox", "vuetify_label": ["last name"] },
      "cachedSelector": null,
      "cachedConfidence": 0.0
    },
    "edit-personal-email": {
      "match": { "role": "textbox", "vuetify_label": ["personal", "recovery"] },
      "cachedSelector": null,
      "cachedConfidence": 0.0
    }
  },

  "chain": [
    {
      "stepId": "s1",
      "action": "navigate",
      "url": "{{base_url}}/organization/people",
      "note": "Go to the people list"
    },
    {
      "stepId": "s2",
      "action": "delay",
      "ms": 1500,
      "note": "Wait for page to fully render"
    },
    {
      "stepId": "s3",
      "action": "type",
      "target": "search-input",
      "value": "{{user_identifier}}",
      "responseSignature": [
        { "type": "element_visible", "selector": "table tbody tr", "timeout": 2000 }
      ],
      "note": "Search for the user"
    },
    {
      "stepId": "s4",
      "action": "find_row",
      "identifier": "{{user_identifier}}",
      "note": "Click into the user's detail page"
    },
    {
      "stepId": "s5",
      "action": "delay",
      "ms": 2000,
      "note": "Wait for detail page to load"
    },
    {
      "stepId": "s6",
      "action": "click_text",
      "text": "Edit",
      "note": "Click Edit to switch from view mode to edit mode"
    },
    {
      "stepId": "s6b",
      "action": "delay",
      "ms": 1500,
      "note": "Wait for edit form to render"
    },
    {
      "stepId": "s6c",
      "action": "read",
      "candidates": [],
      "store_as": "edit_form_snapshot",
      "note": "Snapshot the edit form to verify inputs are available"
    },
    {
      "stepId": "s7",
      "action": "type",
      "target": "edit-first-name",
      "value": "{{new_first_name}}",
      "condition": "{{new_first_name}}",
      "note": "Update first name if provided"
    },
    {
      "stepId": "s8",
      "action": "type",
      "target": "edit-last-name",
      "value": "{{new_last_name}}",
      "condition": "{{new_last_name}}",
      "note": "Update last name if provided"
    },
    {
      "stepId": "s9",
      "action": "type",
      "target": "edit-personal-email",
      "value": "{{new_personal_email}}",
      "condition": "{{new_personal_email}}",
      "note": "Update personal email if provided"
    },
    {
      "stepId": "s10",
      "action": "click",
      "target": "save-button",
      "note": "Click Save/Update to persist changes"
    },
    {
      "stepId": "s11",
      "action": "delay",
      "ms": 2000,
      "note": "Wait for save confirmation"
    },
    {
      "stepId": "s12",
      "action": "read",
      "candidates": [".v-snackbar--active .v-snackbar__content", ".v-alert .v-alert__content", ".v-snackbar .v-snackbar__content"],
      "store_as": "confirmation_message",
      "note": "Read the save confirmation message"
    }
  ]
}
