{
  "_meta": {
    "task": "view-access-grid",
    "description": "Navigate to the access grid and capture the people × applications matrix.",
    "params": [
      "base_url"
    ],
    "selfImproving": true,
    "runCount": 6,
    "lastSuccess": "2026-04-13T03:37:58.515Z",
    "auth": {
      "type": "sso_automatable",
      "googleAccountEmail": "mw@mike-wolf.com"
    },
    "lastDurationMs": 3167
  },
  "params": {
    "base_url": "https://app.yeshid.com"
  },
  "chain": [
    {
      "stepId": "s1",
      "action": "assess_state",
      "expect": {
        "state": "authenticated"
      },
      "onMismatch": "exit_with_error:not-authenticated"
    },
    {
      "stepId": "s2",
      "action": "navigate",
      "url": "{{base_url}}/access/grid"
    },
    {
      "stepId": "s3",
      "action": "delay",
      "ms": 2000,
      "note": "Access grid loads slowly — extra wait"
    },
    {
      "stepId": "s4",
      "action": "assess_state",
      "expect": {
        "state": "access-grid"
      }
    },
    {
      "stepId": "s5",
      "action": "read",
      "selector": ".v-data-table",
      "store_as": "access_grid_data",
      "note": "Capture the full access grid table"
    }
  ],
  "stateGraph": {
    "nodes": {
      "unauthenticated": {
        "signals": [
          {
            "type": "url_matches",
            "pattern": "/login|/auth|/signin|accounts\\.google\\.com"
          }
        ]
      },
      "authenticated": {
        "signals": [
          {
            "type": "url_matches",
            "pattern": "app\\.yeshid\\.com"
          },
          {
            "type": "url_not_matches",
            "pattern": "/login|/auth|/signin|accounts\\.google\\.com"
          }
        ]
      },
      "people-list": {
        "signals": [
          {
            "type": "url_matches",
            "pattern": "/organization/people$"
          }
        ]
      },
      "onboard-form": {
        "signals": [
          {
            "type": "url_matches",
            "pattern": "/organization/people/onboard"
          }
        ]
      },
      "person-detail": {
        "signals": [
          {
            "type": "url_matches",
            "pattern": "/organization/people/[a-z0-9-]+"
          },
          {
            "type": "url_not_matches",
            "pattern": "/onboard|/offboard"
          }
        ]
      },
      "directories": {
        "signals": [
          {
            "type": "url_matches",
            "pattern": "/organization/directories"
          }
        ]
      },
      "access-grid": {
        "signals": [
          {
            "type": "url_matches",
            "pattern": "/access/grid"
          }
        ]
      },
      "events": {
        "signals": [
          {
            "type": "url_matches",
            "pattern": "/events$"
          }
        ]
      }
    }
  }
}
