{
  "_meta": {
    "task": "user-delete",
    "description": "Delete (offboard) a user from YeshID by name or email. Searches the people list, opens the person's profile, clicks Manage → Offboard, and confirms.",
    "params": [
      "user_identifier"
    ],
    "paramNotes": {
      "user_identifier": "Name or email of the user to delete. Used to search the people table."
    },
    "selfImproving": true,
    "runCount": 1,
    "lastSuccess": "2026-04-01T21:46:34.307Z",
    "prerequisite": "00-login.payload.json",
    "warning": "Destructive action. Verify user_identifier before running in production mode."
  },
  "runId": "yeshid-user-delete-{{timestamp}}",
  "mode": "verification",
  "site": "app.yeshid.com",
  "params": {
    "user_identifier": "{{user_identifier}}",
    "base_url": "https://app.yeshid.com"
  },
  "stateGraph": {
    "currentNode": "authenticated",
    "nodes": {
      "authenticated": {
        "signals": [
          {
            "type": "element_visible",
            "selector": ".v-navigation-drawer a[href='/overview']"
          }
        ]
      },
      "people-list": {
        "signals": [
          {
            "type": "url_matches",
            "pattern": "/organization/people$"
          }
        ]
      },
      "person-detail": {
        "signals": [
          {
            "type": "url_matches",
            "pattern": "/organization/people/[a-z0-9-]+/details"
          }
        ]
      }
    }
  },
  "abstractTargets": {
    "search-input": {
      "match": {
        "vuetify_label": [
          "search",
          "filter",
          "name"
        ],
        "name_contains": [
          "search"
        ]
      },
      "cachedSelector": "#input-v-26",
      "cachedConfidence": 0.88,
      "resolvedOn": "2026-03-31T00:00:00Z",
      "description": "Search input on people list page"
    },
    "person-row": {
      "match": {
        "role": "row",
        "name_contains": [
          "{{user_identifier}}"
        ]
      },
      "cachedSelector": null,
      "cachedConfidence": 0,
      "resolveHint": "Find <tr> in the people table whose text contains user_identifier."
    },
    "manage-button": {
      "match": {
        "role": "button",
        "name_contains": [
          "manage"
        ]
      },
      "cachedSelector": "button[aria-haspopup='menu'].bg-primary",
      "cachedConfidence": 0.9,
      "resolvedOn": "2026-04-01T00:00:00Z",
      "fallbackSelectors": [
        "button[aria-haspopup='menu'].bg-primary",
        "main button.bg-primary"
      ],
      "description": "Green 'Manage' dropdown button on person detail page (top-right). Must be scoped to main to avoid sidebar nav group."
    },
    "offboard-menu-item": {
      "match": {
        "role": "menuitem",
        "name_contains": [
          "offboard"
        ]
      },
      "cachedSelector": null,
      "cachedConfidence": 0,
      "fallbackSelectors": [
        ".v-overlay--active .v-list-item",
        ".v-menu__content .v-list-item"
      ],
      "description": "Offboard option in the Manage dropdown menu"
    },
    "confirm-offboard-button": {
      "match": {
        "role": "button",
        "name_contains": [
          "offboard",
          "confirm",
          "yes"
        ]
      },
      "cachedSelector": null,
      "cachedConfidence": 0,
      "fallbackSelectors": [
        ".v-overlay--active .v-btn--variant-flat:last-child",
        ".v-dialog .v-btn.bg-primary"
      ],
      "description": "Confirm button on the offboard page or dialog"
    }
  },
  "chain": [
    {
      "stepId": "s1",
      "action": "navigate",
      "url": "{{base_url}}/organization/people",
      "expect": {
        "state": "people-list"
      }
    },
    {
      "stepId": "s1b",
      "action": "wait_for",
      "selector": "input[placeholder*='Search' i], input[placeholder*='search' i]",
      "timeout": 5000,
      "note": "Wait for Vue app to render the search input after page navigation."
    },
    {
      "stepId": "s2",
      "action": "type",
      "target": "search-input",
      "value": "{{user_identifier}}",
      "guard": {
        "target": "search-input",
        "state": {
          "visible": true,
          "enabled": true
        }
      },
      "responseSignature": [
        {
          "type": "element_visible",
          "selector": "table tbody tr",
          "timeout": 2000
        }
      ]
    },
    {
      "stepId": "s2b",
      "action": "delay",
      "ms": 1500,
      "note": "Wait for Vue search debounce to filter the table."
    },
    {
      "stepId": "s3",
      "action": "find_row",
      "identifier": "{{user_identifier}}",
      "store_as": "find_result",
      "note": "Find the matching row and click the name link to navigate to person detail page."
    },
    {
      "stepId": "s4",
      "action": "wait_for",
      "url_pattern": "/organization/people/[a-z0-9-]+/details",
      "timeout": 8000,
      "note": "Wait for Vue router to navigate to the person detail page."
    },
    {
      "stepId": "s5",
      "action": "click",
      "selector": "button[aria-haspopup='menu']",
      "note": "Click the Manage dropdown button to reveal offboard option."
    },
    {
      "stepId": "s6",
      "action": "click_text",
      "text": "Offboard",
      "note": "Click 'Offboard' from the Manage dropdown menu."
    },
    {
      "stepId": "s7",
      "action": "wait_for",
      "url_pattern": "/offboard/",
      "timeout": 5000,
      "note": "Wait for navigation to the offboard page."
    },
    {
      "stepId": "s8",
      "action": "click_text",
      "text": "Select offboarding date",
      "note": "Open the date picker dropdown."
    },
    {
      "stepId": "s9",
      "action": "click_text",
      "text": "Immediately",
      "note": "Select 'Immediately' from the date options."
    },
    {
      "stepId": "s10",
      "action": "click_text",
      "text": "Offboard person",
      "note": "Confirm offboarding."
    },
    {
      "stepId": "s11",
      "action": "delay",
      "ms": 2000,
      "note": "Wait for offboard API call to complete."
    },
    {
      "stepId": "s12",
      "action": "navigate",
      "url": "{{base_url}}/organization/people",
      "note": "Navigate back to people list to verify offboard succeeded."
    },
    {
      "stepId": "s12b",
      "action": "wait_for",
      "selector": "input[placeholder*='Search' i], input[placeholder*='search' i]",
      "timeout": 5000,
      "note": "Wait for people list to render."
    },
    {
      "stepId": "s13",
      "action": "type",
      "target": "search-input",
      "value": "{{user_identifier}}",
      "note": "Search for the user again to verify status."
    },
    {
      "stepId": "s13b",
      "action": "delay",
      "ms": 1500,
      "note": "Wait for Vue search debounce."
    },
    {
      "stepId": "s14",
      "action": "perceive",
      "store_as": "result_state",
      "note": "Capture final state — expect user row showing 'Deactivated' status."
    }
  ]
}
