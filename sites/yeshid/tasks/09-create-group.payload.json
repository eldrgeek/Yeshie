{
  "_meta": {
    "task": "create-group",
    "description": "Create a new group with name, type, and description.",
    "params": {
      "group_name": {
        "required": true,
        "description": "Name for the new group"
      },
      "group_description": {
        "required": false,
        "default": "",
        "description": "Description of the group (optional)"
      }
    },
    "selfImproving": true,
    "runCount": 0,
    "lastSuccess": null,
    "auth": {
      "type": "sso_automatable",
      "googleAccountEmail": "mw@mike-wolf.com"
    },
    "requiredParams": [
      "group_name"
    ],
    "optionalParams": [
      "group_description"
    ]
  },
  "params": {
    "base_url": "https://app.yeshid.com",
    "group_name": "",
    "group_description": ""
  },
  "chain": [
    {
      "stepId": "s1",
      "action": "assess_state",
      "expect": {
        "state": "authenticated"
      },
      "onMismatch": "exit_with_error:not-authenticated"
    },
    {
      "stepId": "s2",
      "action": "navigate",
      "url": "{{base_url}}/organization/groups"
    },
    {
      "stepId": "s3",
      "action": "delay",
      "ms": 2000
    },
    {
      "stepId": "s4",
      "action": "click_text",
      "text": "New Group",
      "note": "Open New Group dialog"
    },
    {
      "stepId": "s5",
      "action": "delay",
      "ms": 1500,
      "note": "Wait for dialog to render"
    },
    {
      "stepId": "s6",
      "action": "type",
      "selector": "input[placeholder='e.g. Finance Team']",
      "value": "{{group_name}}",
      "note": "Type group name"
    },
    {
      "stepId": "s7",
      "action": "type",
      "selector": "textarea[placeholder='e.g. All US-based finance employees']",
      "value": "{{group_description}}",
      "note": "Type group description"
    },
    {
      "stepId": "s8",
      "action": "click_text",
      "text": "Create Group",
      "responseSignature": {
        "type": "snackbar_text",
        "selector": ".v-snackbar--active .v-snackbar__content"
      },
      "note": "Click Create Group button"
    }
  ],
  "stateGraph": {
    "nodes": {
      "unauthenticated": {
        "signals": [
          {
            "type": "url_matches",
            "pattern": "/login|/auth|/signin|accounts\\.google\\.com"
          }
        ]
      },
      "authenticated": {
        "signals": [
          {
            "type": "url_matches",
            "pattern": "app\\.yeshid\\.com"
          },
          {
            "type": "url_not_matches",
            "pattern": "/login|/auth|/signin|accounts\\.google\\.com"
          }
        ]
      },
      "people-list": {
        "signals": [
          {
            "type": "url_matches",
            "pattern": "/organization/people$"
          }
        ]
      },
      "onboard-form": {
        "signals": [
          {
            "type": "url_matches",
            "pattern": "/organization/people/onboard"
          }
        ]
      },
      "person-detail": {
        "signals": [
          {
            "type": "url_matches",
            "pattern": "/organization/people/[a-z0-9-]+"
          },
          {
            "type": "url_not_matches",
            "pattern": "/onboard|/offboard"
          }
        ]
      },
      "directories": {
        "signals": [
          {
            "type": "url_matches",
            "pattern": "/organization/directories"
          }
        ]
      },
      "access-grid": {
        "signals": [
          {
            "type": "url_matches",
            "pattern": "/access/grid"
          }
        ]
      },
      "events": {
        "signals": [
          {
            "type": "url_matches",
            "pattern": "/events$"
          }
        ]
      }
    }
  }
}