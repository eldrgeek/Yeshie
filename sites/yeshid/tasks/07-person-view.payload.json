{
  "_meta": {
    "task": "person-view",
    "description": "Search for a person and navigate to their detail profile page.",
    "params": {
      "user_identifier": {
        "required": true,
        "description": "Name or email of the person to view"
      }
    },
    "selfImproving": true,
    "runCount": 0,
    "lastSuccess": null,
    "auth": {
      "type": "sso_automatable",
      "googleAccountEmail": "mw@mike-wolf.com"
    },
    "requiredParams": [
      "user_identifier"
    ],
    "optionalParams": []
  },
  "params": {
    "base_url": "https://app.yeshid.com",
    "user_identifier": ""
  },
  "chain": [
    {
      "stepId": "s1",
      "action": "assess_state",
      "expect": {
        "state": "authenticated"
      },
      "onMismatch": "exit_with_error:not-authenticated"
    },
    {
      "stepId": "s2",
      "action": "navigate",
      "url": "{{base_url}}/organization/people"
    },
    {
      "stepId": "s3",
      "action": "delay",
      "ms": 1500
    },
    {
      "stepId": "s4",
      "action": "find_row",
      "identifier": "{{user_identifier}}",
      "store_as": "found_person",
      "note": "Find and click the row matching the user identifier"
    },
    {
      "stepId": "s5",
      "action": "delay",
      "ms": 1500,
      "note": "Wait for person detail page to load"
    },
    {
      "stepId": "s6",
      "action": "assess_state",
      "expect": {
        "state": "person-detail"
      }
    },
    {
      "stepId": "s7",
      "action": "read",
      "store_as": "person_details",
      "note": "Capture the person detail page content"
    }
  ],
  "stateGraph": {
    "nodes": {
      "unauthenticated": {
        "signals": [
          {
            "type": "url_matches",
            "pattern": "/login|/auth|/signin|accounts\\.google\\.com"
          }
        ]
      },
      "authenticated": {
        "signals": [
          {
            "type": "url_matches",
            "pattern": "app\\.yeshid\\.com"
          },
          {
            "type": "url_not_matches",
            "pattern": "/login|/auth|/signin|accounts\\.google\\.com"
          }
        ]
      },
      "people-list": {
        "signals": [
          {
            "type": "url_matches",
            "pattern": "/organization/people$"
          }
        ]
      },
      "onboard-form": {
        "signals": [
          {
            "type": "url_matches",
            "pattern": "/organization/people/onboard"
          }
        ]
      },
      "person-detail": {
        "signals": [
          {
            "type": "url_matches",
            "pattern": "/organization/people/[a-z0-9-]+"
          },
          {
            "type": "url_not_matches",
            "pattern": "/onboard|/offboard"
          }
        ]
      },
      "directories": {
        "signals": [
          {
            "type": "url_matches",
            "pattern": "/organization/directories"
          }
        ]
      },
      "access-grid": {
        "signals": [
          {
            "type": "url_matches",
            "pattern": "/access/grid"
          }
        ]
      },
      "events": {
        "signals": [
          {
            "type": "url_matches",
            "pattern": "/events$"
          }
        ]
      }
    }
  }
}
