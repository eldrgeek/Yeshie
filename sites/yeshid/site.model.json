{
  "_meta": {
    "layer": 3,
    "name": "YeshID Site Model",
    "description": "State graph, abstract target registry, and observed response signatures for app.yeshid.com. This file is the accumulation of all learning from running payloads against YeshID. It is updated automatically after each successful run via the self-improvement merge protocol.",
    "version": "0.1",
    "site": "app.yeshid.com",
    "framework": "vue",
    "frameworkDetail": "Vuetify 3 (v-application detected). No ARIA labels on form inputs. Use vuetify_label_match resolution.",
    "lastExplored": "2026-03-30",
    "exploredBy": "manual live session"
  },

  "stateGraph": {
    "nodes": {
      "unauthenticated": {
        "description": "User is not logged in. Redirected to login page.",
        "signals": [
          { "type": "url_matches", "pattern": "/login|/auth|/signin" },
          { "type": "element_visible", "selector": "input[type='email'], input[type='password']" }
        ]
      },
      "authenticated": {
        "description": "User is logged in. Navigation sidebar is visible.",
        "signals": [
          { "type": "element_visible", "selector": ".v-navigation-drawer a[href='/overview']" },
          { "type": "url_not_matches", "pattern": "/login|/auth|/signin" }
        ]
      },
      "dashboard": {
        "description": "Overview/dashboard page.",
        "signals": [
          { "type": "url_matches", "pattern": "/overview$" },
          { "type": "element_visible", "selector": "a[href='/organization/people/onboard']" }
        ]
      },
      "people-list": {
        "description": "People management list page.",
        "signals": [
          { "type": "url_matches", "pattern": "/organization/people$" },
          { "type": "element_visible", "selector": "button, .v-data-table" }
        ],
        "knownElements": {
          "onboard-button": "The 'Onboard person' button at top of page",
          "search-input": "Search box for filtering people",
          "people-table": "v-data-table with columns: YeshID account owner, Primary email, Directory synced, YeshID status, # of applications"
        }
      },
      "onboard-form": {
        "description": "Add new person form.",
        "signals": [
          { "type": "url_matches", "pattern": "/organization/people/onboard" },
          { "type": "element_visible", "selector": "button" }
        ],
        "knownElements": {
          "first-name-input": "First name text field",
          "last-name-input": "Last name text field",
          "company-email-input": "Company email address field (@ mike-wolf.com domain)",
          "personal-email-input": "Personal / recovery email address field",
          "submit-button": "'Create and onboard person' button"
        }
      },
      "person-detail": {
        "description": "Individual person profile/edit page.",
        "signals": [
          { "type": "url_matches", "pattern": "/organization/people/[a-z0-9-]+" },
          { "type": "url_not_matches", "pattern": "/onboard|/offboard" }
        ]
      },
      "applications-list": {
        "description": "Application management list page.",
        "signals": [
          { "type": "url_matches", "pattern": "/access/applications$" }
        ],
        "knownElements": {
          "add-application-button": "'Add application' button",
          "import-button": "'Import application list' button",
          "apps-table": "Table with columns: Application, Status, Available Integrations, Accounts, Technical Owners, Actions"
        }
      },
      "application-detail": {
        "description": "Application accounts/detail page.",
        "signals": [
          { "type": "url_matches", "pattern": "/access/applications/[a-z0-9-]+/accounts" }
        ],
        "knownElements": {
          "manage-integration-button": "'Manage Integration' button",
          "connect-button": "'Connect' button (when not integrated)"
        }
      },
      "integration-config": {
        "description": "Integration authentication configuration page.",
        "signals": [
          { "type": "url_matches", "pattern": "/access/applications/[a-z0-9-]+/integration/authentication" }
        ],
        "knownElements": {
          "scim-option": "SCIM radio option",
          "build-own-option": "'Build your own' radio option",
          "auth-type-selector": "Authentication Type selector (Bearer, OAuth2, Basic, Custom API key, None)",
          "base-url-input": "Base URL field",
          "save-button": "'Save' button",
          "disconnect-button": "'Disconnect' button"
        }
      }
    },

    "transitions": [
      { "from": "unauthenticated", "to": "authenticated", "via": "login-form-submit" },
      { "from": "authenticated", "to": "dashboard", "via": "navigate /overview" },
      { "from": "authenticated", "to": "people-list", "via": "navigate /organization/people" },
      { "from": "people-list", "to": "onboard-form", "via": "click Onboard person OR navigate /organization/people/onboard" },
      { "from": "people-list", "to": "person-detail", "via": "click person row" },
      { "from": "onboard-form", "to": "people-list", "via": "Create and onboard person success" },
      { "from": "authenticated", "to": "applications-list", "via": "navigate /access/applications" },
      { "from": "applications-list", "to": "application-detail", "via": "click application row" },
      { "from": "application-detail", "to": "integration-config", "via": "click Manage Integration" }
    ]
  },

  "abstractTargets": {
    "nav-people": {
      "description": "People nav link in sidebar",
      "match": { "role": "link", "name_contains": ["people"] },
      "cachedSelector": ".v-navigation-drawer a[href='/organization/people']",
      "cachedConfidence": 0.99
    },
    "nav-applications": {
      "description": "Applications nav link in sidebar",
      "match": { "role": "link", "name_contains": ["applications"] },
      "cachedSelector": ".v-navigation-drawer a[href='/access/applications']",
      "cachedConfidence": 0.99
    },
    "onboard-button": {
      "description": "Onboard person button on people list page",
      "match": { "role": "button", "name_contains": ["onboard"] },
      "cachedSelector": null,
      "cachedConfidence": 0.0,
      "fallbackSelectors": ["button"],
      "resolveHint": "Find button with text 'Onboard person' on /organization/people page"
    },
    "search-input": {
      "description": "Search/filter input on list pages",
      "match": { "role": "textbox", "name_contains": ["search"] },
      "vuetify_label": ["search"],
      "cachedSelector": "input[placeholder='Search']",
      "cachedConfidence": 0.90
    },
    "first-name-input": {
      "description": "First name text field on onboard form",
      "match": { "role": "textbox", "vuetify_label": ["first name"] },
      "cachedSelector": null,
      "cachedConfidence": 0.0,
      "resolveHint": "Vuetify input with label 'First name'. ID changes each session — resolve by label proximity."
    },
    "last-name-input": {
      "description": "Last name text field on onboard form",
      "match": { "role": "textbox", "vuetify_label": ["last name"] },
      "cachedSelector": null,
      "cachedConfidence": 0.0,
      "resolveHint": "Vuetify input with label 'Last name'."
    },
    "company-email-input": {
      "description": "Company email address field on onboard form",
      "match": { "role": "textbox", "vuetify_label": ["company email"] },
      "cachedSelector": null,
      "cachedConfidence": 0.0,
      "resolveHint": "Vuetify input with label 'Company email address'."
    },
    "personal-email-input": {
      "description": "Personal/recovery email field on onboard form",
      "match": { "role": "textbox", "vuetify_label": ["personal", "recovery"] },
      "cachedSelector": null,
      "cachedConfidence": 0.0,
      "resolveHint": "Vuetify input with label 'Personal / recovery email address'."
    },
    "create-onboard-button": {
      "description": "Submit button on onboard form",
      "match": { "role": "button", "name_contains": ["create and onboard", "onboard person"] },
      "cachedSelector": null,
      "cachedConfidence": 0.0,
      "fallbackSelectors": ["button.v-btn--variant-flat"]
    },
    "add-application-button": {
      "description": "Add application button on applications list page",
      "match": { "role": "button", "name_contains": ["add application"] },
      "cachedSelector": null,
      "cachedConfidence": 0.0,
      "resolveHint": "Button with text 'Add application' on /access/applications page."
    },
    "application-name-input": {
      "description": "Application name input in Add Application dialog",
      "match": { "role": "textbox", "name_contains": ["application name"] },
      "cachedSelector": null,
      "cachedConfidence": 0.0,
      "fallbackSelectors": [".v-overlay--active input[placeholder*='application name' i]"]
    },
    "technical-owners-input": {
      "description": "Technical owners autocomplete in Add Application dialog",
      "match": { "role": "textbox", "name_contains": ["technical owner", "owner"] },
      "cachedSelector": null,
      "cachedConfidence": 0.0,
      "fallbackSelectors": [".v-overlay--active input[placeholder*='owner' i]"]
    },
    "dialog-add-button": {
      "description": "The 'Add' confirm button inside any dialog",
      "match": { "role": "button", "name_contains": ["add", "create", "save", "confirm"] },
      "cachedSelector": null,
      "cachedConfidence": 0.0,
      "fallbackSelectors": [".v-overlay--active .v-btn--variant-flat:last-child", ".v-overlay--active button:last-child"]
    },
    "dialog-cancel-button": {
      "description": "Cancel button in any dialog",
      "match": { "role": "button", "name_contains": ["cancel"] },
      "cachedSelector": null,
      "cachedConfidence": 0.0,
      "fallbackSelectors": [".v-overlay--active button"]
    },
    "manage-integration-button": {
      "description": "Manage Integration button on application detail page",
      "match": { "role": "button", "name_contains": ["manage integration"] },
      "cachedSelector": null,
      "cachedConfidence": 0.0,
      "resolveHint": "Button with text 'Manage Integration' on application detail page."
    },
    "base-url-input": {
      "description": "Base URL field on integration config page",
      "match": { "role": "textbox", "vuetify_label": ["base url", "root api url"] },
      "cachedSelector": null,
      "cachedConfidence": 0.0
    },
    "integration-save-button": {
      "description": "Save button on integration config page",
      "match": { "role": "button", "name_contains": ["save"] },
      "cachedSelector": null,
      "cachedConfidence": 0.0,
      "fallbackSelectors": ["button.v-btn--variant-flat"]
    }
  },

  "observedResponseSignatures": {
    "onboard-person-success": {
      "description": "After clicking 'Create and onboard person', a success snackbar appears and URL returns to people list.",
      "signals": [
        { "any_of": [
          { "type": "url_change", "matches": "/organization/people$", "timeout": 5000 },
          { "type": "element_visible", "selector": ".v-snackbar--active", "timeout": 5000 }
        ]}
      ]
    },
    "dialog-opened": {
      "description": "A Vuetify dialog has opened.",
      "signals": [
        { "type": "element_visible", "selector": ".v-overlay--active .v-overlay__content", "timeout": 2000 }
      ]
    },
    "dialog-closed": {
      "description": "A Vuetify dialog has closed.",
      "signals": [
        { "type": "element_absent", "selector": ".v-overlay--active", "timeout": 3000 }
      ]
    },
    "integration-saved": {
      "description": "Integration config saved successfully.",
      "signals": [
        { "any_of": [
          { "type": "element_visible", "selector": ".v-snackbar--active", "timeout": 3000 },
          { "type": "attribute_change", "selector": ".v-alert", "attribute": "class", "value": "success", "timeout": 3000 }
        ]}
      ]
    }
  },

  "urlPatterns": {
    "base": "https://app.yeshid.com",
    "login": "https://app.yeshid.com/login",
    "overview": "https://app.yeshid.com/overview",
    "people": "https://app.yeshid.com/organization/people",
    "onboard": "https://app.yeshid.com/organization/people/onboard",
    "offboard": "https://app.yeshid.com/organization/people/offboard",
    "personDetail": "https://app.yeshid.com/organization/people/{id}",
    "applications": "https://app.yeshid.com/access/applications",
    "applicationDetail": "https://app.yeshid.com/access/applications/{id}/accounts",
    "integrationConfig": "https://app.yeshid.com/access/applications/{id}/integration/authentication"
  }
}
