  "stateGraph": {
    "nodes": {
      "unauthenticated": {
        "description": "User is not logged in. Redirected to login page.",
        "signals": [
          {
            "type": "url_matches",
            "pattern": "/login|/auth|/signin"
          },
          {
            "type": "element_visible",
            "selector": "input[type='email'], input[type='password']"
          }
        ]
      },
      "authenticated": {
        "description": "User is logged in. Navigation sidebar is visible.",
        "signals": [
          {
            "type": "element_visible",
            "selector": ".v-navigation-drawer a[href='/overview']"
          },
          {
            "type": "url_not_matches",
            "pattern": "/login|/auth|/signin"
          }
        ]
      },
      "dashboard": {
        "description": "Overview/dashboard page.",
        "signals": [
          {
            "type": "url_matches",
