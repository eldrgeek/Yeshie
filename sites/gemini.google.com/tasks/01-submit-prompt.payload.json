{
  "_meta": {
    "task": "submit-prompt",
    "description": "Submit a prompt to Google Gemini and capture the response.",
    "params": ["prompt", "base_url"],
    "selfImproving": true,
    "runCount": 0,
    "lastSuccess": null
  },
  "params": {
    "base_url": "https://gemini.google.com/app",
    "prompt": "Say hello in exactly one sentence."
  },
  "abstractTargets": {
    "prompt_input": {
      "description": "Gemini rich-textarea contenteditable input",
      "anchors": {
        "ariaLabel": "Enter a prompt here",
        "placeholder": "Enter a prompt here"
      },
      "fallbackSelectors": [
        "[aria-label='Enter a prompt here']",
        "rich-textarea div[contenteditable='true']",
        "div[contenteditable='true'][role='textbox']",
        "div[contenteditable='true']"
      ]
    }
  },
  "chain": [
    {
      "stepId": "s1",
      "action": "assess_state",
      "stateGraph": {
        "nodes": {
          "auth_required": { "signals": [{ "type": "url_matches", "pattern": "accounts\\.google\\.com" }] }
        }
      },
      "onMismatch": "continue",
      "note": "Check for Google auth redirect"
    },
    {
      "stepId": "s2",
      "action": "delay",
      "ms": 800
    },
    {
      "stepId": "s3",
      "action": "type",
      "target": "prompt_input",
      "value": "{{prompt}}",
      "submit": true,
      "note": "Type prompt and press Enter"
    },
    {
      "stepId": "s4",
      "action": "delay",
      "ms": 2000,
      "note": "Allow generation to start"
    },
    {
      "stepId": "s5",
      "action": "wait_for",
      "selector": "button[aria-label='Stop response']",
      "state": { "visible": false },
      "timeout": 120000,
      "note": "Wait until Stop Response button disappears"
    },
    {
      "stepId": "s6",
      "action": "delay",
      "ms": 500
    },
    {
      "stepId": "s7",
      "action": "read",
      "candidates": [
        "model-response:last-of-type",
        ".response-container:last-child",
        "message-content:last-of-type"
      ],
      "store_as": "response",
      "note": "Capture last model response"
    }
  ],
  "site": "gemini.google.com",
  "mode": "exploratory"
}
