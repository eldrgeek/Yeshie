  "stateGraph": {
    "nodes": {
      "unauthenticated": {
        "signals": [
          {
            "type": "url_matches",
            "pattern": "ServiceLogin|/signin|accounts\\.google\\.com/signin"
          }
        ]
      },
      "authenticated": {
        "signals": [
          {
            "type": "url_matches",
            "pattern": "admin\\.google\\.com"
          },
          {
            "type": "url_not_matches",
            "pattern": "ServiceLogin|/signin"
          }
        ]
      },
      "users-list": {
        "signals": [
          {"type": "url_matches", "pattern": "admin\\.google\\.com/ac/users$"}
        ]
      },
      "groups-list": {
        "signals": [
          {"type": "url_matches", "pattern": "admin\\.google\\.com/ac/groups"}
        ]
      },
