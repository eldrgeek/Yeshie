    {
      "stepId": "s13",
      "action": "read",
      "candidates": ["[role='main']"],
      "store_as": "security_page_content",
      "note": "Read the security page — catalog sections, settings, alerts"
    },
    {
      "stepId": "s14",
      "action": "navigate",
      "url": "{{base_url}}/ac/appslist/core",
