        ]
      },
      "storage": {
        "signals": [
          {"type": "url_matches", "pattern": "admin\\.google\\.com/ac/storage"}
        ]
      },
      "account-settings": {
        "signals": [
          {"type": "url_matches", "pattern": "admin\\.google\\.com/ac/accountsettings"}
        ]
      },
      "admin-roles": {
        "signals": [
          {"type": "url_matches", "pattern": "admin\\.google\\.com/ac/roles"}
        ]
      },
      "devices": {
        "signals": [
          {"type": "url_matches", "pattern": "admin\\.google\\.com/ac/devices"}
        ]
      },
      "domains": {
