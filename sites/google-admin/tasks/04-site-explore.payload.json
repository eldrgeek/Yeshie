{
  "_meta": {
    "task": "site-explore",
    "description": "Survey the Google Admin Console. Navigates through the key sections and uses read/assess_state actions to catalog what's available on each page.",
    "params": {
      "base_url": {
        "required": false,
        "description": "Base URL for Google Admin Console",
        "default": "https://admin.google.com"
      }
    },
    "requiredParams": [],
    "optionalParams": ["base_url"],
    "selfImproving": false,
    "runCount": 0,
    "lastSuccess": null,
    "auth": {
      "type": "manual_required",
      "note": "Requires active admin session at admin.google.com."
    }
  },
  "runId": "google-admin-explore-{{timestamp}}",
  "mode": "verification",
  "site": "admin.google.com",
  "params": {
    "base_url": "https://admin.google.com"
  },
  "abstractTargets": {},
  "chain": [
    {
      "stepId": "s1",
      "action": "navigate",
      "url": "{{base_url}}/ac/users",
      "note": "Navigate to Users list"
    },
    {
      "stepId": "s2",
      "action": "wait_for",
      "selector": "[role='main']",
      "timeout": 8000,
      "note": "Wait for main content to render"
    },
    {
      "stepId": "s3",
      "action": "assess_state",
      "store_as": "users_page_state",
      "note": "Assess the users list page state"
    },
    {
      "stepId": "s4",
      "action": "read",
      "candidates": ["[role='main']", "[role='navigation']"],
      "store_as": "users_page_content",
      "note": "Read the full users page — capture headers, table columns, action buttons, filters"
    },
    {
      "stepId": "s5",
      "action": "navigate",
      "url": "{{base_url}}/ac/groups",
      "note": "Navigate to Groups list"
    },
    {
      "stepId": "s6",
      "action": "wait_for",
      "selector": "[role='main']",
      "timeout": 8000,
      "note": "Wait for groups page to render"
    },
    {
      "stepId": "s7",
      "action": "read",
      "candidates": ["[role='main']"],
      "store_as": "groups_page_content",
      "note": "Read the groups page — catalog existing groups, action buttons"
    },
    {
      "stepId": "s8",
      "action": "navigate",
      "url": "{{base_url}}/ac/orgunits",
      "note": "Navigate to Organizational Units"
    },
    {
      "stepId": "s9",
