      "selector": "[role='main']",
      "timeout": 8000,
      "note": "Wait for org units page to render"
    },
    {
      "stepId": "s10",
      "action": "read",
      "candidates": ["[role='main']"],
      "store_as": "orgunits_page_content",
      "note": "Read the organizational units page — catalog OUs, actions"
    },
    {
      "stepId": "s11",
      "action": "navigate",
      "url": "{{base_url}}/ac/security",
      "note": "Navigate to Security settings"
    },
    {
      "stepId": "s12",
      "action": "wait_for",
      "selector": "[role='main']",
      "timeout": 8000,
